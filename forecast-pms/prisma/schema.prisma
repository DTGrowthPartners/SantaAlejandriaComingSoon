// Forecast PMS Online - Santa Alejandría Hotels
// Esquema base. Modelos alineados al brief y a la lógica del forecast Excel real.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────── Enums ──────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  RECEPTION
  ACCOUNTING
  VIEWER
}

enum ReservationStatus {
  PENDING // Reserva creada sin pago
  PENDING_PAYMENT // Link de pago generado, esperando pago
  DEPOSIT_PAID // Abono recibido
  CONFIRMED // Reserva confirmada
  PAID // Pago completo recibido
  CANCELLED // Reserva cancelada
  EXPIRED // Vencida por falta de pago
  NO_SHOW // Huésped no llegó
}

enum PaymentStatus {
  NO_PAYMENT
  LINK_CREATED
  PAYMENT_PENDING
  APPROVED
  REJECTED // "TC negada" en el forecast del hotel
  EXPIRED
  REFUNDED
}

// Canales de reserva. Colores alineados a la leyenda del forecast Excel del hotel.
enum BookingChannel {
  DIRECT // Directo Hotel  → verde  #00A650
  WHATSAPP // WhatsApp     → verde claro #25D366
  BOOKING // Booking.com   → azul   #00B0F0
  EXPEDIA // Expedia       → morado #7030A0
  AIRBNB // Airbnb         → rojo/rosa #FF385C
  WALK_IN // Walk-in       → amarillo #FFC400
  AGENCY // Agencia        → naranja #FF8A00
  OTHER // Otro/Comply     → gris   #9CA3AF
}

// Tipo de sección del ledger "Ingresos y Gastos" (Excel editable del hotel).
enum LedgerSectionKind {
  INCOME  // suma a ingresos del día (valor por habitación, otros ingresos)
  EXPENSE // suma a gastos del día (desayunos, aseo, cocina, nómina...)
  DATA    // operativo, no suma dinero (ocupación, PAX, desayunos x hab, turnos)
}

// ────────────────────────────── Modelos ──────────────────────────────

model Hotel {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("America/Bogota")
  currency  String   @default("COP")
  // true = temporada alta: la reserva web exige prepago total.
  // false = temporada baja: el cliente aparta pagando 1 noche y paga el resto al llegar.
  webPrepayFull Boolean @default(false)
  // true = la reserva web cobra IVA 19% (por defecto). false = la web cobra exento de IVA.
  webApplyIva   Boolean @default(true)
  rooms     Room[]
  users     User[]
  reservations Reservation[]
  ledgerSheets LedgerSheet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(RECEPTION)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId])
}

model Room {
  id           String        @id @default(cuid())
  hotelId      String
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name         String // "101", "203", etc.
  type         String? // Nombre para el forecast (como lo conoce recepción)
  // Tipo comercial de la web (slug del "rooms" de Directus) al que pertenece esta
  // habitación. Es la fuente del ruteo web→PMS: una reserva web de este tipo entra
  // a las habitaciones con este slug. Editable desde el PMS (pantalla Habitaciones).
  directusSlug String?
  capacity     Int           @default(2)
  active       Boolean       @default(true)
  sortOrder    Int           @default(0)
  reservations Reservation[]
  blocks       RoomBlock[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([hotelId, sortOrder])
  @@index([hotelId, directusSlug])
}

model Reservation {
  id                   String               @id @default(cuid())
  number               Int                  @unique @default(autoincrement())
  hotelId              String
  hotel                Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomId               String
  room                 Room                 @relation(fields: [roomId], references: [id])
  guestName            String
  guestPhone           String?
  guestEmail           String?
  channel              BookingChannel       @default(DIRECT)
  checkIn              DateTime             @db.Date
  checkOut             DateTime             @db.Date
  nights               Int
  guestsCount          Int                  @default(1)
  totalAmount          Int                  @default(0) // en COP (sin decimales)
  applyIva             Boolean              @default(true) // true = se cobra IVA 19%; false = exento
  depositRequired      Int                  @default(0)
  paidAmount           Int                  @default(0)
  balanceAmount        Int                  @default(0)
  reservationStatus    ReservationStatus    @default(PENDING)
  paymentStatus        PaymentStatus        @default(NO_PAYMENT)
  notes                String?
  // Campos del FORMATO DE RESERVAS del hotel (recepción)
  roomsCount           Int                  @default(1) // Cantidad de habitaciones
  upgrade              Boolean              @default(false) // Up Grade
  mealPlan             String? // Tipo de plan (alojamiento, desayuno, etc.)
  arrivalTime          String? // Hora de llegada (HH:MM)
  nationality          String? // Nacionalidad
  extraNights          Int                  @default(0) // Noches extras
  company              String? // Empresa
  cardRef              String? // TC. No. (referencia de tarjeta)
  virtualAdvance       Int                  @default(0) // Anticipo por cobro virtual (COP)
  paymentLink          String?
  paymentLinkExpiresAt DateTime?
  // Reserva web con pago online: se auto-elimina si no se paga antes de esta hora.
  holdExpiresAt        DateTime?
  createdById          String?
  payments             Payment[]
  history              ReservationHistory[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([hotelId, roomId, checkIn, checkOut])
  @@index([hotelId, checkIn])
}

model Payment {
  id                String        @id @default(cuid())
  reservationId     String
  reservation       Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider          String        @default("bold")
  providerPaymentId String?
  providerReference String?
  paymentLink       String?
  amount            Int
  status            PaymentStatus @default(PAYMENT_PENDING)
  method            String? // "manual", "link", "efectivo", "transferencia"...
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([provider, providerPaymentId]) // idempotencia: un mismo pago de Bold no se registra dos veces (NULL = pagos manuales, no colisionan)
  @@index([reservationId])
}

model ReservationHistory {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  action        String // "created", "updated", "moved", "payment", "status_change", "cancelled"
  oldData       Json?
  newData       Json?
  userId        String?
  userName      String?
  createdAt     DateTime    @default(now())

  @@index([reservationId, createdAt])
}

model RoomBlock {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, startDate, endDate])
}

model Notification {
  id                String   @id @default(cuid())
  hotelId           String
  kind              String   @default("reservation") // "reservation"
  title             String
  message           String
  reservationNumber Int?
  dismissed         Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([hotelId, dismissed, createdAt])
}

// ───────────────── Ledger "Ingresos y Gastos por día" (Excel editable) ─────────────────
// Réplica editable del Excel mensual del hotel: una hoja por mes, compuesta de
// secciones (bloques del Excel), cada una con filas (habitación/categoría/empleado)
// y celdas por día guardadas en JSON. Totalmente manual e independiente de las
// reservas: recepción agrega/quita/mueve/edita todo a mano. Los totales por día,
// fila y mes se calculan en vivo (no se guardan) para que nunca se descuadren.

model LedgerSheet {
  id          String          @id @default(cuid())
  hotelId     String
  hotel       Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  year        Int
  month       Int // 1-12
  daysInMonth Int             @default(31)
  note        String? // observaciones libres de la hoja del mes
  sections    LedgerSection[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([hotelId, year, month])
  @@index([hotelId, year, month])
}

model LedgerSection {
  id        String            @id @default(cuid())
  sheetId   String
  sheet     LedgerSheet       @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  title     String
  kind      LedgerSectionKind @default(DATA)
  isText    Boolean           @default(false) // true = celdas de texto (control de turnos)
  sortOrder Int               @default(0)
  rows      LedgerRow[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([sheetId, sortOrder])
}

model LedgerRow {
  id        String        @id @default(cuid())
  sectionId String
  section   LedgerSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label     String
  roomId    String? // link opcional a Room (por número de habitación)
  sortOrder Int           @default(0)
  cells     Json          @default("{}") // { "1": 150480, "2": 150000, ... } o texto por día
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([sectionId, sortOrder])
}
