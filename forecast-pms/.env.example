# ── Base de datos (PostgreSQL) ──
# Dev local: usar `npx prisma dev` y pegar aquí su DATABASE_URL.
# Prod (VPS): postgresql://forecast:PASSWORD@localhost:5432/forecast_pms?schema=public
DATABASE_URL="postgresql://forecast:CAMBIAR@localhost:5432/forecast_pms?schema=public"
SHADOW_DATABASE_URL=""

# ── Auth (sesión JWT firmada con jose) ──
# Genera uno con:  openssl rand -hex 32
AUTH_SESSION_SECRET="CAMBIAR-openssl-rand-hex-32"
AUTH_SESSION_DAYS="7"

# ── App ──
NEXT_PUBLIC_APP_NAME="Forecast PMS · Santa Alejandría"
APP_TIMEZONE="America/Bogota"

# ── Bold (pagos) ──
BOLD_API_KEY=""
BOLD_SECRET=""
BOLD_WEBHOOK_SECRET=""
BOLD_RETURN_URL="https://forecast.santalejandriahotels.com/dashboard/reservations"
BOLD_WEBHOOK_URL="https://forecast.santalejandriahotels.com/api/webhooks/bold"
